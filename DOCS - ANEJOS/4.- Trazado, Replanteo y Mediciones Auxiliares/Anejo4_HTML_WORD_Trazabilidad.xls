</Row>
<Row>
<Cell><Data ss:Type="String">HTML de planta</Data></Cell>
<Cell><Data ss:Type="String">Regenerar paquete de PK y matriz HTML-Word</Data></Cell>
<Cell><Data ss:Type="String">Anejo4_PK_* + Anejo4_HTML_WORD_Trazabilidad.*</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">HTML de alzado</Data></Cell>
<Cell><Data ss:Type="String">Regenerar matriz HTML-Word y revisar headings del 2.2</Data></Cell>
<Cell><Data ss:Type="String">Anejo4_HTML_WORD_Trazabilidad.*</Data></Cell>
</Row>
<Row>
<Cell><Data ss:Type="String">Word principal</Data></Cell>
<Cell><Data ss:Type="String">Aplicar solo cambios puntuales</Data></Cell>
<Cell><Data ss:Type="String">DOCX principal consistente</Data></Cell>
</Row>
<Row>
